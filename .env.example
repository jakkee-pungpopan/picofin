# ====== NovaBank environment (DEMO ONLY) ======
# This is a demo banking system. Do not use for real financial transactions.

# --- Postgres ---
POSTGRES_USER=novabank
POSTGRES_PASSWORD=novabank_pw
POSTGRES_DB=novabank
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend API ---
API_PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://novabank:novabank_pw@localhost:5432/novabank?schema=public
REDIS_URL=redis://localhost:6379

# JWT secrets - NEVER hardcode in code. Override in production.
JWT_ACCESS_SECRET=change_me_access_secret_dev_only
JWT_REFRESH_SECRET=change_me_refresh_secret_dev_only
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# --- Admin dashboard ---
ADMIN_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
